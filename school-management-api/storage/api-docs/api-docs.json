{
    "openapi": "3.0.0",
    "info": {
        "title": "School API",
        "description": "Student Management API (Laravel + Swagger)",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Local Server"
        }
    ],
    "paths": {
